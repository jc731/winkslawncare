---
import { Picture } from "astro:assets";
import PageLayout from "../../components/PageLayout.astro";
import PageSection from "../../components/PageSection.astro";
import Button from "../../components/Button.astro";
import Card from "../../components/Card.astro";
import LearnWhatWeKnow from "../../components/LearnWhatWeKnow.astro";
import mowerHero from "../../images/mower_close.jpg";
import mowerStripes from "../../images/mowing-stripes.png";
---
<PageLayout
  title="Mowing — Wink's Lawn Care"
  description="Professional lawn mowing in Champaign, Rantoul, and Central Illinois. Even cuts, tidy yard. Free quote."
  current="home"
>
  <!-- Hero: full-bleed image with overlay and title -->
  <section class="relative left-1/2 -translate-x-1/2 w-screen max-w-none pb-8 sm:pb-12">
    <div class="relative aspect-[21/9] min-h-[200px] w-full overflow-hidden">
      <Picture
        src={mowerHero}
        formats={["avif", "webp"]}
        alt=""
        width={1600}
        height={686}
        widths={[800, 1200, 1600]}
        sizes="100vw"
        class="absolute inset-0 h-full w-full object-cover"
        aria-hidden="true"
      />
      <div
        class="absolute inset-0 bg-slate-900/50 bg-[radial-gradient(ellipse_70%_70%_at_50%_50%,rgba(16,185,129,0.15),_transparent_70%)]"
        aria-hidden="true"
      />
      <div class="absolute inset-0 flex flex-col items-center justify-center px-4 text-center text-white">
        <h1 class="text-3xl font-bold tracking-tight sm:text-4xl lg:text-5xl">Mowing</h1>
        <p class="mt-2 max-w-xl text-lg text-white/90">Even cuts, healthy turf, all season long.</p>
      </div>
    </div>
  </section>

  <PageSection title="What we do" prominent accentHeading>
    <p>
      Regular mowing keeps your lawn healthy, even, and ready to enjoy all season. We cut at the right height for your grass type and conditions so the turf stays strong and looks sharp from the street.
    </p>
    <p>
      Whether you want weekly visits, every other week, or a custom schedule, we can tailor mowing to your property and your budget. We serve <strong>residential</strong> and <strong>commercial</strong> customers in Champaign, Rantoul, Paxton, Mahomet, St. Joseph, and surrounding areas.
    </p>
    <p>
      <strong>Free quotes.</strong> Call or text <a href="tel:+12174876264">(217) 487-6264</a> or <a href="/contact/">send us a message</a> to get started.
    </p>
    <p class="mt-6">
      <Button href="/contact/" variant="primary">Get a free quote</Button>
    </p>
  </PageSection>

  <section class="bg-slate-50">
    <PageSection title="Quality you can see" prominent accentHeading>
      <div class="mt-6 max-w-2xl">
        <Card>
          <Picture
            src={mowerStripes}
            formats={["avif", "webp"]}
            alt="Mowing stripes pattern on a lawn."
            width={560}
            height={374}
            widths={[340, 560]}
            sizes="(max-width: 640px) 100vw, 560px"
            class="mb-3 h-56 w-full rounded-sm object-cover"
          />
          <p class="text-sm text-slate-600">
            We aim for consistent passes and a tidy pattern so your yard looks sharp from the street.
          </p>
        </Card>
      </div>
    </PageSection>
  </section>

  <LearnWhatWeKnow slugs={["how-to-mow-like-a-pro", "mowing-height-by-season", "mowing-stripes-patterns"]} />
</PageLayout>
