---
import { Picture } from "astro:assets";
import PageLayout from "../../components/PageLayout.astro";
import PageSection from "../../components/PageSection.astro";
import Button from "../../components/Button.astro";
import Card from "../../components/Card.astro";
import LearnWhatWeKnow from "../../components/LearnWhatWeKnow.astro";
import cleanupHero from "../../images/lawncare.jpg";
import lawnCloseup from "../../images/lawn_closeup.jpg";
---
<PageLayout
  title="Spring & Fall Cleanup — Wink's Lawn Care"
  description="Spring and Fall Cleanup for residential and commercial in Champaign, Rantoul, Central Illinois. Leaf removal, debris clearing. Free quote."
  current="home"
>
  <!-- Hero: full-bleed image with overlay and title -->
  <section class="relative left-1/2 -translate-x-1/2 w-screen max-w-none pb-8 sm:pb-12">
    <div class="relative aspect-[21/9] min-h-[200px] w-full overflow-hidden">
      <Picture
        src={cleanupHero}
        formats={["avif", "webp"]}
        alt=""
        width={1600}
        height={686}
        widths={[800, 1200, 1600]}
        sizes="100vw"
        class="absolute inset-0 h-full w-full object-cover"
        aria-hidden="true"
      />
      <div
        class="absolute inset-0 bg-slate-900/50 bg-[radial-gradient(ellipse_70%_70%_at_50%_50%,rgba(16,185,129,0.15),_transparent_70%)]"
        aria-hidden="true"
      />
      <div class="absolute inset-0 flex flex-col items-center justify-center px-4 text-center text-white">
        <h1 class="text-3xl font-bold tracking-tight sm:text-4xl lg:text-5xl">Spring & Fall Cleanup</h1>
        <p class="mt-2 max-w-xl text-lg text-white/90">Leaf removal, debris clearing, seasonal prep.</p>
      </div>
    </div>
  </section>

  <PageSection title="What we do" prominent accentHeading>
    <p>
      Spring and Fall Cleanup get your property ready for the season. We remove leaves, sticks, and debris, clear beds and borders, and leave the yard tidy so your lawn can breathe and your landscape looks cared for.
    </p>
    <p>
      We offer <strong>Spring and Fall Cleanup</strong> for both <strong>residential</strong> and <strong>commercial</strong> properties in Champaign, Rantoul, Paxton, Mahomet, St. Joseph, and surrounding areas. One-time or recurring—we can match your needs.
    </p>
    <p>
      <strong>Free quotes.</strong> Call or text <a href="tel:+12174876264">(217) 487-6264</a> or <a href="/contact/">send us a message</a> to get a quote for your property.
    </p>
    <p class="mt-6">
      <Button href="/contact/" variant="primary">Get a free quote</Button>
    </p>
  </PageSection>

  <section class="bg-slate-50">
    <PageSection title="Quality you can see" prominent accentHeading>
      <div class="mt-6 max-w-2xl">
        <Card>
          <Picture
            src={lawnCloseup}
            formats={["avif", "webp"]}
            alt="Well-maintained lawn after cleanup."
            width={560}
            height={374}
            widths={[340, 560]}
            sizes="(max-width: 640px) 100vw, 560px"
            class="mb-3 h-56 w-full rounded-sm object-cover"
          />
          <p class="text-sm text-slate-600">
            A tidy yard after cleanup sets the stage for a healthy season and a property you can be proud of.
          </p>
        </Card>
      </div>
    </PageSection>
  </section>

  <LearnWhatWeKnow slugs={["spring-lawn-prep", "fall-lawn-care", "seasonal-lawn-care-calendar"]} />
</PageLayout>
