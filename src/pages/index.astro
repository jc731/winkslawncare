---
import { Image, Picture, getImage } from "astro:assets";
import { getCollection, type CollectionEntry } from "astro:content";
import PageLayout from "../components/PageLayout.astro";
import PageSection from "../components/PageSection.astro";
import Container from "../components/Container.astro";
import Button from "../components/Button.astro";
import Card from "../components/Card.astro";
import Badge from "../components/Badge.astro";
import ContactForm from "../components/ContactForm.astro";
import ServiceAreaMap from "../components/ServiceAreaMap.astro";
import heroPosterSource from "../images/lawn_care_low.jpg";
import mowerImage from "../images/mower_close.jpg";
import edgingImage from "../images/weed_eater_edging.jpg";
import lawnCloseup from "../images/lawn_closeup.jpg";
import mowerAbove from "../images/mower_above.jpg";
import lawncareImageSource from "../images/lawncare.jpg";
import hedgeTrimmingImage from "../images/hedge-trimming.jpg";
import weedControlImage from "../images/weed_control.jpg";

const heroPoster = await getImage({
  src: heroPosterSource,
  width: 824,
  format: "webp",
});

const allPosts = await getCollection("blog", ({ data }) => data.draft !== true);
const homepageSlugs = [
  "why-a-great-lawn-matters",
  "how-to-mow-like-a-pro",
  "seasonal-lawn-care-calendar",
];
const featuredPosts: CollectionEntry<"blog">[] = homepageSlugs
  .map((slug) => allPosts.find((p) => p.id === slug))
  .filter((post): post is CollectionEntry<"blog"> => post != null);
---

<PageLayout
  title="Lawn Care Champaign, IL | Mowing, Edging & Trimming — Wink's Lawn Care"
  description="Professional lawn mowing, edging, and trimming in Champaign, Rantoul, and Central Illinois. Get a free quote. Locally owned."
  current="home"
>
  <>
    <!-- Hero: full-bleed image with overlay and headline -->
    <section
      class="relative left-1/2 -translate-x-1/2 w-screen max-w-none pb-6 sm:pb-12"
    >
      <div
        class="relative min-h-[230px] aspect-[16/9] sm:aspect-[21/9] xl:aspect-[24/9] w-full overflow-hidden"
      >
        <video
          id="hero-video"
          autoplay
          muted
          loop
          playsinline
          preload="metadata"
          poster={heroPoster.src}
          class="absolute inset-0 h-full w-full object-cover"
          aria-hidden="true"
        >
          <source src="/videos/Lawn_Care_Hero_Background_Video.mp4" type="video/mp4" />
        </video>
        <script>
          (function () {
            if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
              const el = document.getElementById("hero-video");
              if (el instanceof HTMLVideoElement) el.pause();
            }
          })();
        </script>
        <div
          class="absolute inset-0 bg-slate-950/60 bg-[radial-gradient(circle_at_top,_rgba(16,185,129,0.28),_transparent_55%),_radial-gradient(circle_at_bottom,_rgba(34,197,94,0.24),_transparent_55%)] mix-blend-multiply"
          aria-hidden="true"
        >
        </div>
        <div
          class="absolute inset-0 flex flex-col items-center justify-center px-4 text-center text-white"
        >
          <Badge
            variant="emerald"
            class="mb-4 hidden bg-emerald-300/90 text-emerald-950 shadow-md shadow-emerald-900/40 backdrop-blur-sm animate-badge-subtle-pulse sm:inline-block"
          >
            Locally owned · Central Illinois
          </Badge>
          <h1 class="text-3xl font-bold tracking-tight sm:text-5xl lg:text-6xl">
            Lawn care in Central Illinois
          </h1>
          <p
            class="mt-4 max-w-2xl text-lg font-medium text-white/90 sm:text-xl"
          >
            Mowing, edging, and trimming — we keep your lawn looking sharp.<span
              class="hidden sm:inline"
            >
              Champaign and surrounding areas.</span
            >
          </p>
          <Button href="/#contact" variant="secondary" class="mt-6">
            Get a free quote
          </Button>
        </div>
      </div>
    </section>

    <!-- Services -->
    <section>
      <PageSection title="Services" prominent accentHeading>
        <p>
          We offer <strong>mowing</strong>, <strong>edging</strong>, and <strong
            >trimming</strong
          > to keep your lawn looking sharp, plus <strong
            >Spring and Fall Cleanup</strong
          >, <strong>hedge trimming</strong> (residential and commercial), and <strong
            >weed removal / weed treatment</strong
          > for areas on your property (commercial). We can tailor a schedule to your
          property. <strong>Free quotes</strong> for all services.
        </p>
        <div class="mt-6 grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
          <a
            href="/services/mowing/"
            class="group block no-underline text-inherit"
          >
            <Card
              class="transition hover:border-emerald-200 hover:shadow-md h-full"
            >
              <Picture
                src={mowerImage}
                formats={["avif", "webp"]}
                alt="Lawn mower for mowing service."
                width={560}
                height={374}
                widths={[340, 560]}
                sizes="(max-width: 640px) 100vw, 340px"
                class="mb-3 h-56 w-full rounded-sm object-cover"
              />
              <h3
                class="text-lg font-semibold text-slate-900 group-hover:text-emerald-700"
              >
                Mowing
              </h3>
              <p class="mt-1 text-sm text-slate-600">
                Regular cuts to keep your yard even, tidy, and ready to enjoy
                all season long.
              </p>
            </Card>
          </a>
          <a
            href="/services/edging-trimming/"
            class="group block no-underline text-inherit"
          >
            <Card
              class="transition hover:border-emerald-200 hover:shadow-md h-full"
            >
              <Picture
                src={edgingImage}
                formats={["avif", "webp"]}
                alt="Weed eater and edging along a walkway."
                width={560}
                height={374}
                widths={[340, 560]}
                sizes="(max-width: 640px) 100vw, 340px"
                class="mb-3 h-56 w-full rounded-sm object-cover"
              />
              <h3
                class="text-lg font-semibold text-slate-900 group-hover:text-emerald-700"
              >
                Edging & Trimming
              </h3>
              <p class="mt-1 text-sm text-slate-600">
                Clean lines along sidewalks, driveways, and beds for a crisp,
                finished look.
              </p>
            </Card>
          </a>
          <a
            href="/services/spring-fall-cleanup/"
            class="group block no-underline text-inherit"
          >
            <Card
              class="transition hover:border-emerald-200 hover:shadow-md h-full"
            >
              <Picture
                src={lawnCloseup}
                formats={["avif", "webp"]}
                alt="Well-maintained lawn after seasonal Cleanup."
                width={560}
                height={374}
                widths={[340, 560]}
                sizes="(max-width: 640px) 100vw, 340px"
                class="mb-3 h-56 w-full rounded-sm object-cover"
              />
              <h3
                class="text-lg font-semibold text-slate-900 group-hover:text-emerald-700"
              >
                Spring & Fall Cleanup
              </h3>
              <p class="mt-1 text-sm text-slate-600">
                Leaf removal, debris clearing, and seasonal prep for <strong
                  >residential</strong
                > and <strong>commercial</strong> properties. Free quotes.
              </p>
            </Card>
          </a>
          <a
            href="/services/scheduled-maintenance/"
            class="group block no-underline text-inherit"
          >
            <Card
              class="transition hover:border-emerald-200 hover:shadow-md h-full"
            >
              <Picture
                src={mowerAbove}
                formats={["avif", "webp"]}
                alt="Lawn mower at work — scheduled maintenance."
                width={560}
                height={374}
                widths={[340, 560]}
                sizes="(max-width: 640px) 100vw, 340px"
                class="mb-3 h-56 w-full rounded-sm object-cover"
              />
              <h3
                class="text-lg font-semibold text-slate-900 group-hover:text-emerald-700"
              >
                Scheduled Maintenance
              </h3>
              <p class="mt-1 text-sm text-slate-600">
                We come on a set schedule so your lawn stays consistently cared
                for. Residential and commercial.
              </p>
            </Card>
          </a>
          <a
            href="/services/hedge-trimming/"
            class="group block no-underline text-inherit"
          >
            <Card
              class="transition hover:border-emerald-200 hover:shadow-md h-full"
            >
              <Picture
                src={hedgeTrimmingImage}
                formats={["avif", "webp"]}
                alt="Hedge trimming and landscape trimming."
                width={560}
                height={374}
                widths={[340, 560]}
                sizes="(max-width: 640px) 100vw, 340px"
                class="mb-3 h-56 w-full rounded-sm object-cover"
              />
              <h3
                class="text-lg font-semibold text-slate-900 group-hover:text-emerald-700"
              >
                Hedge trimming
              </h3>
              <p class="mt-1 text-sm text-slate-600">
                Shaping and trimming hedges and landscape for a neat look. <strong
                  >Residential</strong
                > and <strong>commercial</strong>.
              </p>
            </Card>
          </a>
          <a
            href="/services/weed-removal/"
            class="group block no-underline text-inherit"
          >
            <Card
              class="transition hover:border-emerald-200 hover:shadow-md h-full"
            >
              <Picture
                src={weedControlImage}
                formats={["avif", "webp"]}
                alt="Weed control and treatment for property areas."
                width={560}
                height={374}
                widths={[340, 560]}
                sizes="(max-width: 640px) 100vw, 340px"
                class="mb-3 h-56 w-full rounded-sm object-cover"
              />
              <h3
                class="text-lg font-semibold text-slate-900 group-hover:text-emerald-700"
              >
                Weed removal & treatment
              </h3>
              <p class="mt-1 text-sm text-slate-600">
                Weed removal and weed treatment for areas on your property. <strong
                  >Commercial</strong
                > service.
              </p>
            </Card>
          </a>
        </div>
      </PageSection>
    </section>

    <!-- Blog hero: background image + CTA to blog -->
    <section class="relative left-1/2 -translate-x-1/2 w-screen max-w-none">
      <div class="relative aspect-[21/9] w-full overflow-hidden">
        <Picture
          src={lawncareImageSource}
          formats={["avif", "webp"]}
          alt=""
          width={1600}
          height={686}
          widths={[800, 1200, 1600]}
          sizes="100vw"
          class="absolute inset-0 h-full w-full object-cover"
          aria-hidden="true"
        />
        <div
          class="absolute inset-0 bg-slate-900/50 bg-[radial-gradient(ellipse_70%_70%_at_50%_50%,rgba(16,185,129,0.15),_transparent_70%)]"
          aria-hidden="true"
        >
        </div>
        <div
          class="absolute inset-0 flex flex-col items-center justify-center px-4 text-center text-white"
        >
          <h2 class="text-3xl font-bold tracking-tight sm:text-4xl lg:text-5xl">
            Learn what you can do
          </h2>
          <p class="mt-3 max-w-xl text-lg text-white/90">
            Tips and how-tos for mowing, edging, and maintaining a healthier,
            better-looking lawn all year round.
          </p>
          <Button href="/blog/" variant="secondary" class="mt-6">
            Read the blog
          </Button>
        </div>
      </div>
    </section>

    <!-- Our work -->
    <section class="bg-slate-50">
      <PageSection title="Our work" prominent accentHeading>
        <p>Quality mowing and clean edges — we take pride in the details.</p>
        <div class="mt-6 grid grid-cols-1 gap-5 sm:grid-cols-2">
          <Card>
            <Picture
              src={lawnCloseup}
              formats={["avif", "webp"]}
              alt="Close-up of a well-maintained lawn."
              width={560}
              height={374}
              widths={[340, 560]}
              sizes="(max-width: 640px) 100vw, 340px"
              class="mb-3 h-56 w-full rounded-sm object-cover"
            />
            <h3 class="text-lg font-semibold text-slate-900">
              Thick, healthy turf
            </h3>
            <p class="mt-1 text-sm text-slate-600">
              Strong, even growth that looks great from the street and feels
              good underfoot.
            </p>
          </Card>
          <Card>
            <Picture
              src={mowerAbove}
              formats={["avif", "webp"]}
              alt="Lawn mower at work from above."
              width={560}
              height={374}
              widths={[340, 560]}
              sizes="(max-width: 640px) 100vw, 340px"
              class="mb-3 h-56 w-full rounded-sm object-cover"
            />
            <h3 class="text-lg font-semibold text-slate-900">
              Clean passes & patterns
            </h3>
            <p class="mt-1 text-sm text-slate-600">
              Straight, consistent cuts that make your yard stand out in the
              neighborhood.
            </p>
          </Card>
        </div>
      </PageSection>
    </section>

    <!-- Areas we serve (hidden for now; revisit later)
    <PageSection title="Areas we serve" prominent>
      <p>
        Central Illinois, primarily around Rantoul and the Champaign area. We
        serve <strong>Champaign</strong>, <strong>Rantoul</strong>, <strong
          >Paxton</strong
        >, <strong>Mahomet</strong>, <strong>St. Joseph</strong>, and
        surrounding towns.
      </p>
      <div class="mt-6">
        <ServiceAreaMap />
      </div>
    </PageSection>
    -->

    <!-- Blog: learn what you can do -->
    <PageSection title="Learn what you can do" prominent>
      <p class="mb-6">
        Practical tips and how-tos for a healthier, better-looking lawn — from
        mowing and edging to seasonal care.
      </p>
      <ul class="grid list-none gap-4 p-0 sm:grid-cols-2 lg:grid-cols-3">
        {
          featuredPosts.map((post) => (
            <li>
              <a
                href={`/blog/${post.id}`}
                class="group block rounded-sm border border-slate-200 bg-white p-4 no-underline shadow-sm transition hover:border-emerald-200 hover:shadow-md sm:p-5"
              >
                <h3 class="font-semibold text-slate-900 group-hover:text-emerald-700">
                  {post.data.title}
                </h3>
                <p class="mt-1.5 text-sm text-slate-600 line-clamp-2">
                  {post.data.description}
                </p>
                <span class="mt-2 inline-block text-sm font-medium text-emerald-700 group-hover:underline">
                  Read more →
                </span>
              </a>
            </li>
          ))
        }
      </ul>
      <p class="mt-6">
        <a
          href="/blog/"
          class="inline-flex min-h-[48px] min-w-[48px] items-center py-2 font-medium text-emerald-700 no-underline hover:underline"
          >View all articles</a
        >
      </p>
    </PageSection>

    <!-- CTA band (stereotypical Tailwind marketing block) -->
    <section class="bg-emerald-700 py-12 sm:py-16">
      <Container>
        <div class="mx-auto max-w-2xl text-center">
          <h2 class="text-3xl font-bold tracking-tight text-white sm:text-4xl">
            Ready for a greener lawn?
          </h2>
          <p class="mt-4 text-lg text-white">
            Call or text <a
              href="tel:+12174876264"
              class="inline-block min-h-[48px] py-2 leading-none font-semibold text-white underline hover:no-underline"
              >(217) 487-6264</a
            > for a free quote. We serve Champaign, Rantoul, Paxton, Mahomet, St.
            Joseph, and surrounding areas.
          </p>
          <Button href="/#contact" variant="secondary" class="mt-6">
            Get a free quote
          </Button>
        </div>
      </Container>
    </section>

    <!-- Contact form (bottom of page; hero/CTA "Get a free quote" link to #contact) -->
    <section id="contact">
      <PageSection title="Contact" prominent>
        <p>
          Call or text for a free quote: <a
            href="tel:+12174876264"
            class="inline-block min-h-[48px] py-2 leading-none font-semibold text-emerald-700 no-underline hover:underline"
            >(217) 487-6264</a
          >. Or send us a message:
        </p>
        <div class="mt-6 max-w-xl">
          <ContactForm />
        </div>
      </PageSection>
    </section>
  </>
</PageLayout>
