---
import { Image, Picture, getImage } from 'astro:assets';
import { getCollection } from 'astro:content';
import PageLayout from '../components/PageLayout.astro';
import PageSection from '../components/PageSection.astro';
import Container from '../components/Container.astro';
import Button from '../components/Button.astro';
import Card from '../components/Card.astro';
import Badge from '../components/Badge.astro';
import ContactForm from '../components/ContactForm.astro';
import heroPosterSource from '../images/lawn_care_low.jpg';
import heroVideo from '../images/Lawn_Care_Hero_Background_Video.mp4';
import mowerImage from '../images/mower_close.jpg';
import edgingImage from '../images/weed_eater_edging.jpg';
import lawnCloseup from '../images/lawn_closeup.jpg';
import mowerAbove from '../images/mower_above.jpg';

const heroPoster = await getImage({
  src: heroPosterSource,
  width: 824,
  format: 'webp',
});

const allPosts = await getCollection('blog', ({ data }) => data.draft !== true);
const homepageSlugs = ['why-a-great-lawn-matters', 'how-to-mow-like-a-pro', 'seasonal-lawn-care-calendar'];
const featuredPosts = homepageSlugs
  .map((slug) => allPosts.find((p) => p.id === slug))
  .filter(Boolean);
---

<PageLayout current="home">
  <>
    <!-- Hero: full-bleed image with overlay and headline -->
    <section class="relative left-1/2 -translate-x-1/2 w-screen max-w-none">
      <div class="relative aspect-[16/9] sm:aspect-[21/9] xl:aspect-[24/9] w-full overflow-hidden">
        <video
          id="hero-video"
          autoplay
          muted
          loop
          playsinline
          preload="metadata"
          poster={heroPoster.src}
          class="absolute inset-0 h-full w-full object-cover"
          aria-hidden="true"
        >
          <source src={heroVideo} type="video/mp4" />
        </video>
        <script>
          (function () {
            if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
              const el = document.getElementById('hero-video');
              if (el instanceof HTMLVideoElement) el.pause();
            }
          })();
        </script>
        <div
          class="absolute inset-0 bg-slate-950/60 bg-[radial-gradient(circle_at_top,_rgba(16,185,129,0.28),_transparent_55%),_radial-gradient(circle_at_bottom,_rgba(34,197,94,0.24),_transparent_55%)] mix-blend-multiply"
          aria-hidden="true"
        />
        <div class="absolute inset-0 flex flex-col items-center justify-center px-4 text-center text-white">
          <Badge
            variant="emerald"
            class="mb-4 bg-emerald-300/90 text-emerald-950 shadow-md shadow-emerald-900/40 backdrop-blur-sm animate-badge-subtle-pulse"
          >
            Locally owned · Central Illinois
          </Badge>
          <h1 class="text-4xl font-bold tracking-tight sm:text-5xl lg:text-6xl">
            Lawn care in Central Illinois
          </h1>
          <p class="mt-4 max-w-2xl text-lg font-medium text-white/90 sm:text-xl">
            Mowing, edging, and trimming — we keep your lawn looking sharp. Champaign and surrounding areas.
          </p>
          <Button href="/#contact" variant="secondary" class="mt-6 bg-white text-slate-900 hover:bg-white/90">
            Get a free quote
          </Button>
        </div>
      </div>
    </section>

    <!-- Services: green-tinted gradient for differentiation -->
    <section class="relative overflow-hidden bg-gradient-to-b from-white via-white to-emerald-50/70 bg-[radial-gradient(ellipse_80%_60%_at_70%_20%,rgba(167,243,208,0.35),transparent_50%)]">
      <PageSection title="Services" prominent>
      <p>We offer <strong>mowing</strong>, <strong>edging</strong>, and <strong>trimming</strong> to keep your lawn looking sharp. Regular maintenance or one-time cleanups — we can tailor a schedule to your property. Rates: contact us for a quote.</p>
      <div class="mt-6 grid grid-cols-1 gap-5 sm:grid-cols-2">
        <Card>
          <Picture
          src={mowerImage}
          formats={['avif', 'webp']}
          alt="Lawn mower for mowing service."
          width={560}
          height={374}
          widths={[340, 560]}
          sizes="(max-width: 640px) 100vw, 340px"
          class="mb-3 h-56 w-full rounded-xl object-cover"
        />
          <h3 class="text-lg font-semibold text-slate-900">Mowing</h3>
          <p class="mt-1 text-sm text-slate-600">
            Regular cuts to keep your yard even, tidy, and ready to enjoy all season long.
          </p>
        </Card>
        <Card>
          <Picture
          src={edgingImage}
          formats={['avif', 'webp']}
          alt="Weed eater and edging along a walkway."
          width={560}
          height={374}
          widths={[340, 560]}
          sizes="(max-width: 640px) 100vw, 340px"
          class="mb-3 h-56 w-full rounded-xl object-cover"
        />
          <h3 class="text-lg font-semibold text-slate-900">Edging & trimming</h3>
          <p class="mt-1 text-sm text-slate-600">
            Clean lines along sidewalks, driveways, and beds for a crisp, finished look.
          </p>
        </Card>
      </div>
      </PageSection>
    </section>

    <!-- Our work: different tint so sections feel unique -->
    <section class="relative overflow-hidden bg-gradient-to-b from-slate-50 via-emerald-50/20 to-slate-50 bg-[radial-gradient(ellipse_60%_80%_at_30%_80%,rgba(110,231,183,0.25),transparent_45%)]">
      <PageSection title="Our work" prominent>
        <p>Quality mowing and clean edges — we take pride in the details.</p>
        <div class="mt-6 grid grid-cols-1 gap-5 sm:grid-cols-2">
          <Card>
            <Picture
            src={lawnCloseup}
            formats={['avif', 'webp']}
            alt="Close-up of a well-maintained lawn."
            width={560}
            height={374}
            widths={[340, 560]}
            sizes="(max-width: 640px) 100vw, 340px"
            class="mb-3 h-56 w-full rounded-xl object-cover"
          />
            <h3 class="text-lg font-semibold text-slate-900">Thick, healthy turf</h3>
            <p class="mt-1 text-sm text-slate-600">
              Strong, even growth that looks great from the street and feels good underfoot.
            </p>
          </Card>
          <Card>
            <Picture
            src={mowerAbove}
            formats={['avif', 'webp']}
            alt="Lawn mower at work from above."
            width={560}
            height={374}
            widths={[340, 560]}
            sizes="(max-width: 640px) 100vw, 340px"
            class="mb-3 h-56 w-full rounded-xl object-cover"
          />
            <h3 class="text-lg font-semibold text-slate-900">Clean passes & patterns</h3>
            <p class="mt-1 text-sm text-slate-600">
              Straight, consistent cuts that make your yard stand out in the neighborhood.
            </p>
          </Card>
        </div>
      </PageSection>
    </section>

    <!-- Areas we serve -->
    <PageSection title="Areas we serve" prominent>
      <p>Central Illinois, primarily around Rantoul and the Champaign area. We serve <strong>Champaign</strong>, <strong>Rantoul</strong>, <strong>Paxton</strong>, <strong>Mahomet</strong>, <strong>St. Joseph</strong>, and surrounding towns.</p>
    </PageSection>

    <!-- Blog: learn what you can do -->
    <PageSection title="Learn what you can do" prominent>
      <p class="mb-6">Practical tips and how-tos for a healthier, better-looking lawn — from mowing and edging to seasonal care.</p>
      <ul class="grid list-none gap-4 p-0 sm:grid-cols-2 lg:grid-cols-3">
        {featuredPosts.map((post) => (
          <li>
            <a href={`/blog/${post.id}`} class="group block rounded-xl border border-slate-200 bg-white p-4 no-underline shadow-sm transition hover:border-emerald-200 hover:shadow-md sm:p-5">
              <h3 class="font-semibold text-slate-900 group-hover:text-emerald-700">
                {post.data.title}
              </h3>
              <p class="mt-1.5 text-sm text-slate-600 line-clamp-2">
                {post.data.description}
              </p>
              <span class="mt-2 inline-block text-sm font-medium text-emerald-600 group-hover:underline">
                Read more →
              </span>
            </a>
          </li>
        ))}
      </ul>
      <p class="mt-6">
        <a href="/blog/" class="font-medium text-emerald-600 no-underline hover:underline">View all articles</a>
      </p>
    </PageSection>

    <!-- CTA band (stereotypical Tailwind marketing block) -->
    <section class="bg-emerald-600 py-12 sm:py-16">
      <Container>
        <div class="mx-auto max-w-2xl text-center">
          <h2 class="text-3xl font-bold tracking-tight text-white sm:text-4xl">
            Ready for a greener lawn?
          </h2>
          <p class="mt-4 text-lg text-emerald-100">
            Call or text <a href="tel:+12174876264" class="font-semibold text-white underline hover:no-underline">(217) 487-6264</a> for a free quote. We serve Champaign, Rantoul, Paxton, Mahomet, St. Joseph, and surrounding areas.
          </p>
          <a
            href="/#contact"
            class="mt-6 inline-flex items-center justify-center rounded-lg bg-white px-6 py-3 text-base font-semibold text-emerald-600 no-underline shadow-sm hover:bg-white/90 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white"
          >
            Get a free quote
          </a>
        </div>
      </Container>
    </section>

    <!-- Contact form (bottom of page; hero/CTA "Get a free quote" link to #contact) -->
    <section id="contact">
      <PageSection title="Contact" prominent>
        <p>Call or text for a free quote: <a href="tel:+12174876264" class="font-semibold text-emerald-600 no-underline hover:underline">(217) 487-6264</a>. Or send us a message:</p>
        <div class="mt-6 max-w-xl">
          <ContactForm />
        </div>
      </PageSection>
    </section>
  </>
</PageLayout>
