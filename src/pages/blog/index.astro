---
import { getCollection } from 'astro:content';
import PageLayout from '../../components/PageLayout.astro';
import PageSection from '../../components/PageSection.astro';
import Button from '../../components/Button.astro';

const posts = (await getCollection('blog', ({ data }) => data.draft !== true))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<PageLayout title="Blog — Wink's Lawn Care" description="Blog and updates from Wink's Lawn Care." current="blog">
  <header class="py-12 sm:py-16" slot="header">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h1 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">Blog</h1>
      <p class="mt-2 text-lg text-slate-600">Tips, updates, and news.</p>
    </div>
  </header>

  <PageSection>
    {posts.length === 0 ? (
      <p>No posts yet. Add markdown files in <code>src/content/blog/</code> — see DO_THIS.md.</p>
    ) : (
      <ul class="list-none m-0 p-0">
        {posts.map((post) => (
          <li class="mb-4 flex flex-col gap-1 sm:flex-row sm:items-center sm:justify-between">
            <div>
              <a href={`/blog/${post.id}`} class="font-medium text-emerald-600 no-underline hover:underline">{post.data.title}</a>
              <time datetime={post.data.pubDate.toISOString()} class="mt-1 block text-sm text-slate-500">
                {post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
              </time>
            </div>
            <Button href={`/blog/${post.id}`} size="sm" variant="ghost" class="mt-1 sm:mt-0">
              Read post
            </Button>
          </li>
        ))}
      </ul>
    )}
  </PageSection>
</PageLayout>
