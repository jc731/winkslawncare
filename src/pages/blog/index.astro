---
import Layout from '../../layouts/Layout.astro';
// Blog listing — add Astro content collection and real posts when ready (see DO_THIS.md)
---

<Layout title="Blog — Wink's Lawn Care" description="Blog and updates from Wink's Lawn Care.">
  <main class="page">
    <header class="header">
      <h1>Blog</h1>
      <p class="tagline">Tips, updates, and news.</p>
    </header>

    <nav class="nav">
      <a href="/">Home</a>
      <a href="/blog/">Blog</a>
    </nav>

    <section class="section">
      <p>No posts yet. Add content via Astro content collections (e.g. <code>src/content/blog/</code>) when ready — see DO_THIS.md.</p>
    </section>

    <footer class="footer">
      <p><a href="/">Wink's Lawn Care</a> · Central Illinois</p>
    </footer>
  </main>
</Layout>

<style>
  .page {
    max-width: 42rem;
    margin: 0 auto;
    padding: 2rem 1rem;
  }
  .header {
    margin-bottom: 1.5rem;
  }
  .header h1 {
    font-size: 1.75rem;
    font-weight: 700;
    margin: 0 0 0.5rem;
  }
  .tagline {
    color: #555;
    margin: 0;
    font-size: 1rem;
  }
  .nav {
    margin-bottom: 2rem;
  }
  .nav a {
    margin-right: 1rem;
    color: #0d6efd;
    text-decoration: none;
  }
  .nav a:hover {
    text-decoration: underline;
  }
  .section {
    margin-bottom: 2rem;
  }
  .section p {
    margin: 0;
    color: #444;
    line-height: 1.5;
  }
  .section code {
    background: #f0f0f0;
    padding: 0.2em 0.4em;
    border-radius: 4px;
    font-size: 0.9em;
  }
  .section a {
    color: #0d6efd;
    text-decoration: none;
  }
  .footer {
    margin-top: 3rem;
    padding-top: 1rem;
    border-top: 1px solid #eee;
    font-size: 0.9rem;
    color: #666;
  }
</style>
