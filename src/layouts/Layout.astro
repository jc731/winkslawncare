---
import ogImage from '../images/winks_logo.png';

interface Props {
  title?: string;
  description?: string;
}
const {
  title = "Wink's Lawn Care",
  description = "Lawn care services in Central Illinois — Champaign area and surrounding.",
} = Astro.props;
const canonicalURL = Astro.site
  ? new URL(Astro.url.pathname, Astro.site).href
  : null;
const ogImageURL = Astro.site
  ? new URL(ogImage.src, Astro.site).href
  : ogImage.src;
const siteName = "Wink's Lawn Care";
---

<!doctype html>
<html lang="en" class="min-h-full">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    {canonicalURL && <link rel="canonical" href={canonicalURL} />}

    <!-- Open Graph / link preview (Facebook, Messenger, Telegram, iMessage, etc.) -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />
    {canonicalURL && <meta property="og:url" content={canonicalURL} />}

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class="min-h-full w-full m-0 font-sans antialiased">
    <slot />
  </body>
</html>
