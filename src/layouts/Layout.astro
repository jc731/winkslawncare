---
interface Props {
  title?: string;
  description?: string;
}
const { title = "Wink's Lawn Care", description = "Lawn care services in Central Illinois — Champaign area and surrounding." } = Astro.props;
---
<!doctype html>
<html lang="en" class="min-h-full">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class="min-h-full w-full m-0 font-sans antialiased">
    <slot />
  </body>
</html>
