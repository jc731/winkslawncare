---
interface Props {
  title?: string;
  description?: string;
}
const { title = "Wink's Lawn Care", description = "Lawn care services in Central Illinois — Champaign area and surrounding." } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  html, body {
    margin: 0;
    width: 100%;
    min-height: 100%;
    font-family: system-ui, -apple-system, sans-serif;
  }
</style>
