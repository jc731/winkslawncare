---
import Layout from '../layouts/Layout.astro';
import Container from './Container.astro';
import Nav from './Nav.astro';
import Footer from './Footer.astro';
import Button from './Button.astro';

interface Props {
  title?: string;
  description?: string;
  current?: 'home' | 'blog' | 'contact';
}
const { title, description, current } = Astro.props;
---
<Layout title={title} description={description}>
  <div class="flex flex-col min-h-full bg-white">
    <header class="py-5 sm:py-6">
      <Container>
        <nav class="relative flex items-center justify-between gap-6">
          <a href="/" class="text-xl font-semibold tracking-tight text-slate-900 no-underline hover:text-slate-700">
            Wink's Lawn Care
          </a>
          <div class="flex items-center gap-6 sm:gap-8">
            <Nav current={current} />
            <Button href="/contact/" size="sm">
              Get a quote
            </Button>
          </div>
        </nav>
      </Container>
    </header>

    <main class="flex-1 overflow-x-hidden">
      <slot name="header" />
      <slot />
    </main>

    <Footer />
  </div>
</Layout>
