---
interface Props {
  title?: string;
  id?: string;
  /** If true, use larger section heading and more vertical padding (for main content sections) */
  prominent?: boolean;
  /** If true, heading gets a soft green outline and slightly lighter text color */
  accentHeading?: boolean;
}
const { title, id, prominent = false, accentHeading = false } = Astro.props;
---
<section class:list={[prominent ? 'py-12 sm:py-16' : 'py-8 sm:py-10']} id={id}>
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    {title && (
      <h2 class:list={[
        'font-semibold tracking-tight',
        prominent ? 'text-3xl sm:text-4xl' : 'text-xl sm:text-2xl',
        accentHeading
          ? 'text-slate-700 [-webkit-text-stroke:1px_rgba(16,185,129,0.35)]'
          : 'text-slate-900'
      ]}>
        {title}
      </h2>
    )}
    <div class:list={[
      'mt-4 text-slate-600 leading-relaxed [&_p]:m-0 [&_p]:mb-4 [&_a:not([data-btn])]:text-emerald-600 [&_a:not([data-btn])]:font-medium [&_a:not([data-btn])]:no-underline [&_a:not([data-btn]):hover]:underline [&_code]:bg-slate-100 [&_code]:px-1.5 [&_code]:py-0.5 [&_code]:rounded [&_code]:text-sm',
      title && (prominent ? 'mt-5' : 'mt-2')
    ]}>
      <slot />
    </div>
  </div>
</section>
