---
interface Props {
  variant?: 'emerald' | 'slate' | 'zinc';
  class?: string;
}

const {
  variant = 'emerald',
  class: className,
} = Astro.props;

const variantClass =
  variant === 'slate'
    ? 'bg-slate-100 text-slate-700'
    : variant === 'zinc'
    ? 'bg-zinc-100 text-zinc-700'
    : 'bg-emerald-100 text-emerald-700';
---
<span
  class:list={[
    'inline-flex items-center rounded-full px-3 py-1 text-xs font-medium',
    variantClass,
    className,
  ]}
>
  <slot />
</span>

