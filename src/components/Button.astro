---
/**
 * Button — Primitive CTA/link component.
 *
 * Use for primary actions (quote, submit), secondary actions on dark/hero
 * backgrounds (white button), and tertiary/outline actions (emerald outline).
 *
 * Variants:
 *   - primary:   Green background, white text. Main CTAs (e.g. Get a free quote, Submit).
 *   - secondary: White background, dark text. For use on hero/CTA bands and dark overlays.
 *   - tertiary:  Emerald outline + emerald text, transparent bg. Lower emphasis (e.g. nav-style).
 *
 * Use `href` for links (renders <a>), omit for <button> (e.g. type="submit").
 * Optional `class` is merged for layout only (e.g. mt-6, w-full); avoid overriding variant colors here.
 */
interface Props {
  href?: string;
  type?: 'button' | 'submit' | 'reset';
  variant?: 'primary' | 'secondary' | 'tertiary';
  size?: 'md' | 'sm';
  class?: string;
}

const {
  href,
  type = 'button',
  variant = 'primary',
  size = 'md',
  class: className,
} = Astro.props;

const base =
  'inline-flex items-center justify-center gap-x-2 rounded-sm font-semibold no-underline focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2';

const sizeClass =
  size === 'sm'
    ? 'min-h-[48px] min-w-[48px] px-3 py-1.5 text-sm'
    : 'min-h-[48px] min-w-[48px] px-4 py-2.5 text-sm sm:text-base';

const variantClass =
  variant === 'primary'
    ? 'bg-emerald-700 text-white shadow-sm hover:bg-emerald-600 focus-visible:outline-emerald-700'
    : variant === 'secondary'
    ? 'bg-white text-slate-900 shadow-sm hover:bg-white/90 focus-visible:outline-white border border-slate-200/80'
    : 'border border-emerald-700 text-emerald-700 bg-white hover:bg-emerald-50 focus-visible:outline-emerald-700';
---
{href ? (
  <a href={href} class:list={[base, sizeClass, variantClass, className]} data-btn>
    <slot />
  </a>
) : (
  <button type={type} class:list={[base, sizeClass, variantClass, className]} data-btn>
    <slot />
  </button>
)}
