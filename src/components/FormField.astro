---
interface Props {
  id: string;
  label: string;
  hint?: string;
  error?: string;
  required?: boolean;
  class?: string;
}

const {
  id,
  label,
  hint,
  error,
  required = false,
  class: className,
} = Astro.props;
---
<div class:list={['space-y-1.5', className]}>
  <label
    for={id}
    class="block text-sm font-medium text-slate-700"
  >
    {label}
    {required && <span class="ml-1 text-red-500">*</span>}
  </label>
  <div class:list={['mt-1', error && 'rounded-lg ring-1 ring-red-300 bg-red-50/40 px-2 pt-1 pb-1']}>
    <slot />
  </div>
  {hint && !error && (
    <p class="text-xs text-slate-500">
      {hint}
    </p>
  )}
  {error && (
    <p class="text-xs font-medium text-red-600">
      {error}
    </p>
  )}
</div>

