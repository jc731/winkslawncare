---
interface Props {
  as?: keyof HTMLElementTagNameMap;
  class?: string;
}

const {
  as: Tag = 'div',
  class: className,
} = Astro.props;
---
<Tag
  class:list={[
    'rounded-2xl border border-slate-200 bg-white/80 shadow-sm backdrop-blur-sm',
    'p-5 sm:p-6',
    className,
  ]}
>
  <slot name="header" />
  <slot />
  <slot name="footer" />
</Tag>

