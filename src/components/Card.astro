---
interface Props {
  as?: keyof HTMLElementTagNameMap;
  class?: string;
}

const {
  as: Tag = 'div',
  class: className,
} = Astro.props;
---
<Tag
  class:list={[
    'rounded-sm border border-emerald-100 border-t-4 border-t-emerald-400 bg-white shadow-md',
    'p-5 sm:p-6',
    className,
  ]}
>
  <slot name="header" />
  <slot />
  <slot name="footer" />
</Tag>

